{
  "manifest_version": 3,
  "name": "AIUB Portal+",
  "version": "1.5",
  "description": "Extension for AIUB students❤️",
  "permissions": [
    "storage"
  ],
  "icons": {
    "128": "icons/white.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AIUB Portal+",
    "default_icon": {
      "128": "icons/white.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "sakibmahmudsadi@outlook.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://portal.aiub.edu/*"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "https://api.ocr.space/parse/image"
  ]
}
