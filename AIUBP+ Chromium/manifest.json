{
  "manifest_version": 3,
  "name": "AIUB Portal+",
  "version": "1.5",
  "description": "Extension for AIUB students❤️",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/white.png",
    "32": "icons/white.png",
    "48": "icons/white.png",
    "128": "icons/white.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AIUB Portal+",
    "default_icon": {
      "16": "icons/white.png",
      "32": "icons/white.png",
      "48": "icons/white.png",
      "128": "icons/white.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://portal.aiub.edu/*"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "https://api.ocr.space/parse/image"
  ]
}
